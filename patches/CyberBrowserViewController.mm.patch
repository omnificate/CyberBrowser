  // Create initial tab with Google
  [self newTab];
  [self loadURL:GURL("https://www.google.com")];
}

- (void)createWebState {
  if (_webState) {
    _webState->RemoveObserver(_webStateObserver.get());
    _webState.reset();
  }

  web::WebState::CreateParams webStateCreateParams(_browserState);
  _webState = web::WebState::Create(webStateCreateParams);

  _webStateObserver = std::make_unique<web::WebStateObserverBridge>(self);
  _webState->AddObserver(_webStateObserver.get());

  _webStateDelegate = std::make_unique<web::WebStateDelegateBridge>(self);
  _webState->SetDelegate(_webStateDelegate.get());

  UIView* view = _webState->GetView();
  [view setFrame:[_containerView bounds]];
  [_containerView addSubview:view];
}

- (NavigationManager*)navigationManager {
  return _webState->GetNavigationManager();
}

- (web::WebState*)webState {
  return _webState.get();
}

- (void)didReceiveMemoryWarning {
  [super didReceiveMemoryWarning];
}

- (UIBarPosition)positionForBar:(id<UIBarPositioning>)bar {
  if (bar == _toolbarView) {
    return UIBarPositionTopAttached;
  }
  return UIBarPositionAny;
}

#pragma mark - Tab Management

- (void)newTab {
  if (_webState) {
    // Save current URL before switching
    const GURL& currentURL = _webState->GetVisibleURL();
    if (currentURL.is_valid() && _currentTabIndex >= 0 && _currentTabIndex < [_tabURLs count]) {
      _tabURLs[_currentTabIndex] = base::SysUTF8ToNSString(currentURL.spec());
    }
  }

  [_tabURLs addObject:@"https://www.google.com"];
  _currentTabIndex = [_tabURLs count] - 1;
  [self createWebState];
  [self loadURL:GURL("https://www.google.com")];
  [self updateToolbar];
}

- (void)loadURL:(const GURL&)url {
  if (!url.is_valid())
    return;

  NavigationManager::WebLoadParams params(url);
  params.transition_type = ui::PAGE_TRANSITION_TYPED;
  self.navigationManager->LoadURLWithParams(params);

  [self storeHistoryItem:url.spec() title:@""];
}

- (void)storeHistoryItem:(const std::string&)url title:(NSString*)title {
  if (url.empty()) return;

  NSUserDefaults* defaults = [NSUserDefaults standardUserDefaults];
  NSMutableArray* history = [[defaults arrayForKey:@"CyberBrowserHistory"] mutableCopy];
  if (!history) {
    history = [NSMutableArray array];
  }

  NSString* urlString = base::SysUTF8ToNSString(url);
  NSDictionary* item = @{
    @"url": urlString,
    @"title": title ?: @"",
    @"timestamp": [NSDate date]
  };
  [history addObject:item];

  // Keep last 1000 items
  if ([history count] > 1000) {
    [history removeObjectsAtRange:NSMakeRange(0, [history count] - 1000)];
  }

  [defaults setObject:history forKey:@"CyberBrowserHistory"];
  [defaults synchronize];
}

- (void)showHistory {
  NSUserDefaults* defaults = [NSUserDefaults standardUserDefaults];
  NSArray* history = [defaults arrayForKey:@"CyberBrowserHistory"];

  UIAlertController* alert = [UIAlertController alertControllerWithTitle:@"History"
                                                                 message:nil
                                                          preferredStyle:UIAlertControllerStyleActionSheet];

  if ([history count] == 0) {
    [alert addAction:[UIAlertAction actionWithTitle:@"No history yet"
                                              style:UIAlertActionStyleDefault
                                            handler:nil]];
  } else {
    // Show last 20 items
    NSInteger count = MIN([history count], 20);
    for (NSInteger i = [history count] - 1; i >= [history count] - count; i--) {
      NSDictionary* item = history[i];
      NSString* urlString = item[@"url"];
      NSString* displayTitle = item[@"title"];
      if ([displayTitle length] == 0) {
        displayTitle = urlString;
      }
      [alert addAction:[UIAlertAction actionWithTitle:displayTitle
                                                style:UIAlertActionStyleDefault
                                              handler:^(UIAlertAction* action) {
        [self loadURL:GURL(base::SysNSStringToUTF8(urlString))];
      }]];
    }
  }

  [alert addAction:[UIAlertAction actionWithTitle:@"Clear History"
                                            style:UIAlertActionStyleDestructive
                                          handler:^(UIAlertAction* action) {
    [defaults removeObjectForKey:@"CyberBrowserHistory"];
    [defaults synchronize];
  }]];

  [alert addAction:[UIAlertAction actionWithTitle:@"Cancel"
                                            style:UIAlertActionStyleCancel
                                          handler:nil]];

  [self presentViewController:alert animated:YES completion:nil];
}

- (void)goHome {
  [self loadURL:GURL("https://www.google.com")];
}

- (void)reloadPage {
  _webState->GetNavigationManager()->Reload(web::ReloadType::NORMAL, false);
}

- (void)stopLoading {
  _webState->Stop();
}

#pragma mark - Navigation

- (void)back {
  if (self.navigationManager->CanGoBack()) {
    self.navigationManager->GoBack();
  }
}

- (void)forward {
  if (self.navigationManager->CanGoForward()) {
    self.navigationManager->GoForward();
  }
}

#pragma mark - Text Field Delegate

- (BOOL)textFieldShouldReturn:(UITextField*)field {
  NSString* text = [field text];
  GURL URL;

  // Check if it's a search query or URL
  if ([text rangeOfString:@" "].location != NSNotFound ||
      [text rangeOfString:@"."].location == NSNotFound) {
    // It's a search query - use Google
    NSString* encodedQuery = [text stringByAddingPercentEncodingWithAllowedCharacters:[NSCharacterSet URLQueryAllowedCharacterSet]];
    NSString* googleURL = [NSString stringWithFormat:@"https://www.google.com/search?q=%@", encodedQuery];
    URL = GURL(base::SysNSStringToUTF8(googleURL));
  } else {
    URL = GURL(base::SysNSStringToUTF8(text));
    if (!URL.has_scheme()) {
      NSString* fullURL = [NSString stringWithFormat:@"https://%@", text];
      URL = GURL(base::SysNSStringToUTF8(fullURL));
    }
  }

  if (URL.is_valid()) {
    NavigationManager::WebLoadParams params(URL);
    params.transition_type = ui::PAGE_TRANSITION_TYPED;
    self.navigationManager->LoadURLWithParams(params);
  }

  [field resignFirstResponder];
  [self updateToolbar];
  return YES;
}

- (void)updateToolbar {
  if ([_field isFirstResponder]) {
    return;
  }

  const GURL& visibleURL = _webState->GetVisibleURL();
  [_field setText:base::SysUTF8ToNSString(visibleURL.spec())];
}

#pragma mark - Bikeshedding Implementation

- (BOOL)canBecomeFirstResponder {
  return YES;
}

- (void)motionEnded:(UIEventSubtype)motion withEvent:(UIEvent*)event {
  if (event.subtype == UIEventSubtypeMotionShake) {
    [self updateToolbarColor];
  }
}

- (void)updateToolbarColor {
  NSArray* colors = @[
    [UIColor colorWithRed:0.05 green:0.05 blue:0.05 alpha:1.0],
    [UIColor colorWithRed:0.898 green:0.110 blue:0.137 alpha:1.0],
    [UIColor colorWithRed:0.376 green:0.490 blue:0.545 alpha:1.0],
    [UIColor colorWithRed:0.475 green:0.333 blue:0.282 alpha:1.0],
    [UIColor colorWithRed:0.612 green:0.153 blue:0.690 alpha:1.0],
  ];

  NSUInteger currentIndex = [colors indexOfObject:_toolbarView.barTintColor];
  if (currentIndex == NSNotFound) {
    currentIndex = 0;
  }
  NSUInteger newIndex = (currentIndex + 1) % [colors count];
  _toolbarView.barTintColor = [colors objectAtIndex:newIndex];
  _tabToolbar.barTintColor = [colors objectAtIndex:newIndex];
}

#pragma mark - WebStateObserver

- (void)webState:(web::WebState*)webState
    didStartNavigation:(web::NavigationContext*)navigation {
  [self updateToolbar];
  [_progressView setProgress:0.2 animated:YES];
}

- (void)webState:(web::WebState*)webState
    didFinishNavigation:(web::NavigationContext*)navigation {
  [self updateToolbar];
  [_progressView setProgress:1.0 animated:YES];

  dispatch_after(dispatch_time(DISPATCH_TIME_NOW, (int64_t)(0.3 * NSEC_PER_SEC)), dispatch_get_main_queue(), ^{
    [self->_progressView setProgress:0.0 animated:NO];
  });

  // Store history with title
  const GURL& url = webState->GetVisibleURL();
  NSString* title = base::SysUTF8ToNSString(webState->GetTitle());
  [self storeHistoryItem:url.spec() title:title];
}

- (void)webState:(web::WebState*)webState didLoadPageWithSuccess:(BOOL)success {
  DCHECK_EQ(_webState.get(), webState);
  [self updateToolbar];
}

- (void)webState:(web::WebState*)webState didChangeLoadingProgress:(double)progress {
  [_progressView setProgress:progress animated:YES];
}

#pragma mark - WebStateDelegate

- (void)webState:(web::WebState*)webView
    contextMenuConfigurationForParams:(const web::ContextMenuParams&)params
                    completionHandler:(void (^)(UIContextMenuConfiguration*))
                                          completionHandler {
  GURL link = params.link_url;
  void (^copyHandler)(UIAction*) = ^(UIAction* action) {
    NSDictionary* item = @{
      UTTypeURL.identifier : net::NSURLWithGURL(link),
      UTTypeUTF8PlainText.identifier : [base::SysUTF8ToNSString(link.spec())
          dataUsingEncoding:NSUTF8StringEncoding],
    };
    [[UIPasteboard generalPasteboard] setItems:@[ item ]];
  };

  void (^openHandler)(UIAction*) = ^(UIAction* action) {
    [self loadURL:link];
  };

  void (^newTabHandler)(UIAction*) = ^(UIAction* action) {
    [self newTab];
    [self loadURL:link];
  };

  UIContextMenuConfiguration* configuration = [UIContextMenuConfiguration
      configurationWithIdentifier:nil
      previewProvider:^{
        UIViewController* controller = [[UIViewController alloc] init];
        CGRect frame = CGRectMake(10, 200, 200, 21);
        UILabel* label = [[UILabel alloc] initWithFrame:frame];
        label.text = @"CyberBrowser Preview";
        [controller.view addSubview:label];
        return controller;
      }
      actionProvider:^(id _) {
        NSArray* actions = @[
          [UIAction actionWithTitle:@"Open Link"
                              image:nil
                         identifier:nil
                            handler:openHandler],
          [UIAction actionWithTitle:@"Open in New Tab"
                              image:nil
                         identifier:nil
                            handler:newTabHandler],
          [UIAction actionWithTitle:@"Copy Link"
                              image:nil
                         identifier:nil
                            handler:copyHandler],
          [UIAction actionWithTitle:@"Cancel"
                              image:nil
                         identifier:nil
                            handler:^(id ignored){
                            }]
        ];
        NSString* menuTitle = [NSString
            stringWithFormat:@"CyberBrowser: %s", link.spec().c_str()];
        return [UIMenu menuWithTitle:menuTitle children:actions];
      }];

  completionHandler(configuration);
}

- (void)webStateDestroyed:(web::WebState*)webState {
  NOTREACHED();
}

@end
